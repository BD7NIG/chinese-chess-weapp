.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e, #16213e, #0f3460);
  padding: 60rpx 40rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰竖排文字 */
.deco-left {
  position: absolute;
  left: 12rpx;
  top: 70rpx;
  writing-mode: vertical-rl;
  font-size: 22rpx;
  color: rgba(212, 168, 67, 0.08);
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 12rpx;
  user-select: none;
  pointer-events: none;
}

.deco-right {
  position: absolute;
  right: 12rpx;
  bottom: 120rpx;
  writing-mode: vertical-rl;
  font-size: 22rpx;
  color: rgba(212, 168, 67, 0.08);
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 12rpx;
  user-select: none;
  pointer-events: none;
}

/* 标题区域 */
.title-area {
  text-align: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.title {
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  font-size: 60rpx;
  color: #d4a843;
  letter-spacing: 16rpx;
  text-shadow: 0 2rpx 16rpx rgba(212, 168, 67, 0.35);
  line-height: 1.3;
  display: block;
}

.title-en {
  font-size: 20rpx;
  color: rgba(212, 168, 67, 0.25);
  letter-spacing: 12rpx;
  margin-top: 4rpx;
  display: block;
  font-family: serif;
}

.subtitle {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 4rpx;
  display: block;
  letter-spacing: 8rpx;
}

/* 象棋图标 */
.board-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(145deg, #e8c06f, #d4a843);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  position: relative;
  z-index: 1;
  border: 2rpx solid #b8943a;
}

.chess-char {
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  font-size: 80rpx;
  color: #3a2a1a;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
  font-weight: 900;
}

/* 用户信息区 */
.user-section {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a843, #b8943a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #3a2a1a;
  font-weight: 900;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-nickname {
  font-size: 30rpx;
  color: #eee;
  font-weight: 500;
}

.user-stats {
  font-size: 22rpx;
  color: #aaa;
}

.user-arrow {
  font-size: 36rpx;
  color: #666;
}

/* 菜单 */
.menu {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  border: none;
  padding: 0;
  line-height: 96rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-primary .btn-text {
  font-size: 32rpx;
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 4rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.4);
}

.btn-secondary {
  background: #0f3460;
  color: #eee;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.btn-secondary .btn-text {
  font-size: 32rpx;
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 4rpx;
}

.btn-ai {
  background: linear-gradient(135deg, #6c5ce7, #341f97);
  color: white;
  border: 2rpx solid rgba(108, 92, 231, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.3);
}

.btn-ai .btn-icon {
  font-size: 36rpx;
}

.btn-ai .btn-text {
  font-size: 32rpx;
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 4rpx;
}

.btn-setting {
  background: rgba(255, 255, 255, 0.03);
  color: #aaa;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
  height: 76rpx;
  line-height: 76rpx;
  margin-top: 8rpx;
}

.btn-setting .btn-icon {
  font-size: 30rpx;
}

.btn-setting .btn-text {
  font-size: 28rpx;
}

.btn-replay {
  background: rgba(255, 255, 255, 0.03);
  color: #aaa;
  border: 2rpx solid rgba(255, 255, 255, 0.04);
  height: 76rpx;
  line-height: 76rpx;
  margin-top: 4rpx;
}

.btn-replay .btn-icon {
  font-size: 30rpx;
}

.btn-replay .btn-text {
  font-size: 28rpx;
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 4rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 24rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 40rpx;
  z-index: 1;
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-dot.online {
  background: #2ecc71;
  box-shadow: 0 0 8rpx rgba(46, 204, 113, 0.5);
}

.status-dot.offline {
  background: #e74c3c;
  animation: pulse 1.5s infinite;
}

.status-text {
  font-size: 22rpx;
  color: #aaa;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
}

/* ===== 设置弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-overlay.hidden {
  display: none;
}

.settings-panel {
  width: 82%;
  max-width: 580rpx;
  background: #16213e;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
}

.s-title {
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  font-size: 36rpx;
  color: #d4a843;
  text-align: center;
  margin-bottom: 32rpx;
  letter-spacing: 6rpx;
}

.s-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.04);
}

.s-row:last-of-type {
  border-bottom: none;
}

.s-label {
  font-size: 28rpx;
  color: #eee;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.s-desc {
  font-size: 22rpx;
  color: #aaa;
  font-weight: normal;
}

/* 开关 */
.s-toggle {
  width: 80rpx;
  height: 44rpx;
  background: #1a1a2e;
  border-radius: 22rpx;
  position: relative;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.2s;
}

.s-toggle.on {
  background: #e94560;
}

.knob {
  width: 36rpx;
  height: 36rpx;
  background: white;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.s-toggle.on .knob {
  left: 40rpx;
}

/* 选择器 */
.s-picker {
  flex-shrink: 0;
}

.s-select {
  font-size: 26rpx;
  color: #d4a843;
  background: #1a1a2e;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(212, 168, 67, 0.3);
  white-space: nowrap;
}

/* 确认按钮 */
.s-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: white;
  border: none;
  font-size: 30rpx;
  margin-top: 28rpx;
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  letter-spacing: 4rpx;
}

/* 加入房间弹窗 */
.modal-content {
  width: 72%;
  max-width: 520rpx;
  background: #16213e;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-family: "Ma Shan Zheng", "STKaiti", "KaiTi", serif;
  font-size: 34rpx;
  color: #d4a843;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.room-input {
  width: 90%;
  height: 80rpx;
  background: #1a1a2e;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #eee;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.modal-actions {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.modal-btn.cancel {
  background: #1a1a2e;
  color: #aaa;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #e94560, #c0392b);
  color: white;
}
